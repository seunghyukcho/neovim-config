{
  "languageserver": {
    "dockerfile": {
      "command": "docker-langserver",
      "filetypes": ["dockerfile"],
      "args": ["--stdio"]
    }
  },
  "coc.preferences.formatOnSaveFiletypes": [
    "json",
    "python",
    "sh",
    "yaml"
  ],
  "codeLens.enable": true,
  "yaml.format.enable": true,
  "python.pythonPath": "~/.config/nvim/pyright-set.sh",
  "python.jediEnabled": false
}
